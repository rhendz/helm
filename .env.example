# -----------------------------
# Core runtime
# -----------------------------
APP_ENV=local
LOG_LEVEL=INFO
TZ=America/Los_Angeles

# -----------------------------
# API service
# -----------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------
# Database
# -----------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=helm
POSTGRES_USER=helm
POSTGRES_PASSWORD=helm
DATABASE_URL=postgresql+psycopg://helm:helm@postgres:5432/helm

# -----------------------------
# OpenAI
# -----------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# -----------------------------
# Telegram
# -----------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_WEBHOOK_URL=

# -----------------------------
# Scheduling
# -----------------------------
DIGEST_CRON=0 8 * * *
WORKER_POLL_SECONDS=30
# Operator local timezone (IANA format). Required. Scheduling fails if unset.
OPERATOR_TIMEZONE=America/Los_Angeles

# -----------------------------
# Google (Gmail + Calendar)
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# -----------------------------
# Study ingest mode
# -----------------------------
STUDY_INGEST_MODE=manual

# -----------------------------
# Linear tooling
# -----------------------------
LINEAR_API_KEY=
LINEAR_TEAM_KEY=HELM

# -----------------------------
# Datadog (optional — APM traces)
# -----------------------------
DD_ENV=development
DD_SERVICE=helm
DD_VERSION=0.4.0
